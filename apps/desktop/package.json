{
  "name": "@repo/desktop",
  "version": "1.8.0",
  "private": true,
  "type": "module",
  "description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
  "scripts": {
    "stage:catalog": "bun scripts/stage-catalog.ts",
    "start": "bun run stage:catalog && vite build && electrobun dev",
    "dev": "bun run stage:catalog && electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build:canary": "bun run stage:catalog && vite build && electrobun build --env=canary",
    "build:stable": "bun run stage:catalog && vite build && electrobun build --env=stable",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:studio": "bunx drizzle-kit studio",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "bun run src/bun/utils/engine-manager"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "electrobun": "1.16.0",
    "extract-zip": "^2.0.1",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "tar": "^7.5.11",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.4.49",
    "prettier": "^3.7.4",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
